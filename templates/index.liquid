{% schema %}
{
  "name": "Homepage",
  "settings": [
    {"type": "image_picker", "id": "hero_background", "label": "Hero Background Image"},
    {"type": "text", "id": "hero_heading", "label": "Hero Heading", "default": "Welcome to {{ shop.name }}"},
    {"type": "richtext", "id": "hero_subheading", "label": "Hero Subheading", "default": "<p>Discover our amazing products</p>"},
    {"type": "url", "id": "hero_button_link", "label": "Hero Button Link"},
    {"type": "text", "id": "hero_button_text", "label": "Hero Button Text", "default": "Shop Now"}
  ]
}
{% endschema %}

{%- style -%}
.hero-section {
  background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url({{ section.settings.hero_background | img_url: '2000x' }});
  background-size: cover;
  background-position: center;
  min-height: 60vh;
  display: flex;
  align-items: center;
  color: white;
  text-align: center;
  padding: 100px 20px;
}
.hero-content { max-width: 800px; margin: 0 auto; }
.hero-title { font-size: 3rem; margin-bottom: 20px; }
.hero-text { font-size: 1.2rem; line-height: 1.6; margin-bottom: 30px; }
.btn-large { padding: 15px 30px; font-size: 1.1rem; }
{%- endstyle -%}

<div class="hero-section">
  <div class="hero-content">
    {% if section.settings.hero_heading != blank %}
      <h1 class="hero-title">{{ section.settings.hero_heading }}</h1>
    {% endif %}
    {% if section.settings.hero_subheading != blank %}
      <div class="hero-text">{{ section.settings.hero_subheading }}</div>
    {% endif %}
    {% if section.settings.hero_button_link != blank and section.settings.hero_button_text != blank %}
      <a href="{{ section.settings.hero_button_link }}" class="btn btn-primary btn-large">{{ section.settings.hero_button_text }}</a>
    {% endif %}
  </div>
</div>

{% section 'featured-collection' %}
{% section 'featured-product' %}
{% section 'newsletter' %}