{%- style -%}
.footer { background: #000000; color: #ffffff; padding: 60px 0 20px; margin-top: 60px; }
.footer-main { max-width: 1200px; margin: 0 auto; padding: 0 20px; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px; margin-bottom: 40px; }
.footer-column-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 20px; }
.footer-column-content a { color: #cccccc; text-decoration: none; transition: color 0.3s; display: block; margin-bottom: 10px; }
.footer-column-content a:hover { color: #ffffff; }
.footer-social { display: flex; gap: 15px; margin-top: 20px; }
.footer-social-link { width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; text-decoration: none; font-size: 1.1rem; transition: all 0.3s; }
.footer-social-link:hover { background: #000000; transform: translateY(-3px); }
.footer-newsletter-form { display: flex; gap: 10px; margin-top: 15px; }
.footer-newsletter-input { flex: 1; padding: 12px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.1); border-radius: 4px; color: #ffffff; }
.footer-newsletter-btn { padding: 12px 20px; background: #000000; color: #ffffff; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; transition: background 0.3s; }
.footer-bottom { max-width: 1200px; margin: 0 auto; padding: 20px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
.footer-bottom-link { color: #cccccc; text-decoration: none; font-size: 0.9rem; transition: color 0.3s; }
.footer-bottom-link:hover { color: #ffffff; }
.footer-payment { display: flex; gap: 10px; align-items: center; }
.footer-payment img { height: 24px; width: auto; opacity: 0.7; transition: opacity 0.3s; }
.footer-payment img:hover { opacity: 1; }
.footer-copyright { font-size: 0.9rem; color: rgba(255,255,255,0.7); }
@media (max-width: 768px) { .footer-main { grid-template-columns: 1fr; gap: 30px; } .footer-bottom { flex-direction: column; text-align: center; } }
{%- endstyle -%}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {"type": "color", "id": "color_primary", "label": "Primary Color", "default": "#000000"},
    {"type": "text", "id": "facebook_url", "label": "Facebook URL"},
    {"type": "text", "id": "twitter_url", "label": "Twitter URL"},
    {"type": "text", "id": "instagram_url", "label": "Instagram URL"},
    {"type": "checkbox", "id": "show_payment_icons", "label": "Show Payment Icons", "default": true},
    {"type": "text", "id": "copyright_text", "label": "Copyright Text", "default": "&copy; 2026 {{ shop.name }}. All rights reserved."}
  ]
}
{% endschema %}

<footer class="footer">
  <div class="footer-main">
    <div class="footer-column">
      <h3 class="footer-column-title">{{ shop.name }}</h3>
      <div class="footer-column-content">
        <p>Your premium e-commerce destination.</p>
      </div>
    </div>
    <div class="footer-column">
      <h3 class="footer-column-title">Shop</h3>
      <div class="footer-column-content">
        <a href="/collections/all">All Products</a>
        <a href="/collections/featured">Featured</a>
        <a href="/pages/about">About Us</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>
    <div class="footer-column">
      <h3 class="footer-column-title">Help</h3>
      <div class="footer-column-content">
        <a href="/pages/shipping">Shipping</a>
        <a href="/pages/returns">Returns</a>
        <a href="/pages/faq">FAQ</a>
        <a href="/pages/privacy-policy">Privacy Policy</a>
      </div>
    </div>
    <div class="footer-column">
      <h3 class="footer-column-title">Connect</h3>
      <div class="footer-column-content">
        {% if section.settings.facebook_url != blank %}<a href="{{ section.settings.facebook_url }}" class="footer-social-link" title="Facebook"></i class="fab fa-facebook-f"></a>{% endif %}
        {% if section.settings.twitter_url != blank %}<a href="{{ section.settings.twitter_url }}" class="footer-social-link" title="Twitter"></i class="fab fa-twitter"></a>{% endif %}
        {% if section.settings.instagram_url != blank %}<a href="{{ section.settings.instagram_url }}" class="footer-social-link" title="Instagram"></i class="fab fa-instagram"></a>{% endif %}
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div><span class="footer-copyright">{{ section.settings.copyright_text }}</span></div>
    <div>
      {% if section.settings.show_payment_icons %}
        <div class="footer-payment">
          <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/4f8e74f173768b33.svg" alt="Visa" loading="lazy">
          <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/5e3b05b68f3d31b2.svg" alt="Mastercard" loading="lazy">
          <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/055f26d8356629b4.svg" alt="PayPal" loading="lazy">
        </div>
      {% endif %}
    </div>
  </div>
</footer>