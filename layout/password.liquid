<!DOCTYPE html>
<html lang="{{ localization.language.iso_code }}">
<head>
<meta charset="utf-8">
<title>{{ shop.name }} - Password Protected</title>
{{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-password">
<div class="password-page">
<div class="password-content">
{% if shop.password_message != blank %}<h1>{{ shop.password_message }}</h1>{% else %}<h1>Launching Soon!</h1>{% endif %}
<form method="post" action="/contact#contact_form">
<input type="hidden" name="form_type" value="customer">
<input type="email" name="contact[email]" placeholder="Your email" required>
<button type="submit" class="btn btn-primary">Notify Me</button>
</form>
{% if shop.password_enabled %}
<form method="post" action="/login">
<input type="password" name="password" placeholder="Password" required>
<button type="submit" class="btn">Enter</button>
</form>
{% endif %}
</div>
</div>
</body>
</html>