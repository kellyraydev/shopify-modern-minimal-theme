<!DOCTYPE html>
<html lang="{{ localization.language.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} - Password Protected</title>
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <link rel="icon" href="{{ 'favicon.ico' | asset_url }}" type="image/x-icon">
</head>
<body class="template-password">
  <div class="password-page">
    <div class="password-content">
      {% if shop.password_message != blank %}
        <h1>{{ shop.password_message }}</h1>
      {% else %}
        <h1>We are Launching Soon!</h1>
      {% endif %}
      <form method="post" action="/contact#contact_form" id="contact_form">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="&checkmark;">
        <input type="email" name="contact[email]" placeholder="Your email address" required>
        <button type="submit" class="btn btn-primary">Notify Me</button>
      </form>
      {% if shop.password_enabled %}
        <form method="post" action="/login" class="password-login">
          <input type="hidden" name="return_to" value="{{ request.path }}">
          <input type="password" name="password" placeholder="Enter store password" required>
          <button type="submit" class="btn btn-secondary">Enter</button>
        </form>
      {% endif %}
    </div>
  </div>
</body>
</html>